{
  "name": "scratchpad",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:www": "turbo run dev --filter=@orbit/www",
    "predev": "bun run registry",
    "build": "turbo run build",
    "prebuild": "bun run registry",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "registry": "tsx scripts/build-registry.ts",
    "snapshot": "tsx scripts/snapshot.ts"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "playwright": "^1.49.0",
    "tsx": "^4.19.2",
    "turbo": "^2.9.6",
    "typescript": "~6.0.2"
  }
}
